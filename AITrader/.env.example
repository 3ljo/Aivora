# OpenAI — required
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: override default model (defaults to gpt-4.1 if unset)
OPENAI_MODEL=gpt-4.1

# Market data
#  Crypto (BTC/ETH/etc.) → Binance public API, no key needed.
#  Forex / metals / indices / stocks → Twelve Data primary (800 req/day free), Yahoo fallback.
#  Sign up free at https://twelvedata.com/account/api-keys
# TWELVE_DATA_API_KEY=

# ── TELEGRAM NOTIFICATIONS ───────────────────────────────────────────────────
# You set these ONCE as the app owner. End users then just click "Connect
# Telegram" on /settings — they never touch tokens.
#
# Setup (free, ~2 min):
#  1. Open Telegram, chat with @BotFather → send /newbot
#  2. Pick a name + a username ending in "bot" (e.g. signalforge_alerts_bot)
#  3. BotFather gives you a token like 123456:ABC-DEF... — paste as TELEGRAM_BOT_TOKEN
#  4. Put the bot's @username (no @) as TELEGRAM_BOT_USERNAME
# TELEGRAM_BOT_TOKEN=123456:ABCdef...
# TELEGRAM_BOT_USERNAME=signalforge_alerts_bot

# ── MONITOR ──────────────────────────────────────────────────────────────────
# How often the background monitor checks all active alerts (ms). Default 60000.
# MONITOR_INTERVAL_MS=60000
# DISABLE_MONITOR=1    # uncomment to disable the in-process monitor
# CRON_SECRET=shared-secret-for-/api/cron/tick   # optional; required only if you use external cron
